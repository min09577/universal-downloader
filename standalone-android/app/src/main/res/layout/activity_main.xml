<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F1117"
    android:fitsSystemWindows="true">

    <!-- 顶部标题 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="全能下载器"
            android:textColor="#4F6EF7"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0.3"
            android:textColor="#4A4E5E"
            android:textSize="11sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btnPaste"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_small"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:text="📋 粘贴"
            android:textColor="@android:color/white"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- URL 输入区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp">

        <EditText
            android:id="@+id/etUrl"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:hint="粘贴视频/图片链接..."
            android:inputType="textUri"
            android:maxLines="1"
            android:paddingHorizontal="16dp"
            android:textColor="#E1E4ED"
            android:textColorHint="#5A5E6E"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAnalyze"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="识别"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/btnDownload"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:backgroundTint="#F59E0B"
                android:enabled="false"
                android:text="下载"
                android:textColor="@android:color/white" />
        </LinearLayout>
    </LinearLayout>

    <!-- 平台登录 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="登录:"
            android:textColor="#5A5E6E"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/btnLoginBilibili"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_login_btn"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="B站"
            android:textColor="#FB7299"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/btnLoginXhs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_login_btn"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="小红书"
            android:textColor="#FF2442"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/btnLoginDouyin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_login_btn"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="抖音"
            android:textColor="#69C9D0"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- 解析结果 -->
    <LinearLayout
        android:id="@+id/layoutResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvResultTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="#E1E4ED"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvResultPlatform"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#8B8FA8"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 下载进度 -->
    <LinearLayout
        android:id="@+id/layoutProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progressTint="#4F6EF7" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#8B8FA8"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#8B8FA8"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 下载历史标题 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="下载历史"
            android:textColor="#E1E4ED"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnClearHistory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:text="清空"
            android:textColor="#F87171"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 空状态 -->
    <TextView
        android:id="@+id/tvEmptyHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="暂无下载记录\n粘贴链接开始下载吧~"
        android:textAlignment="center"
        android:textColor="#5A5E6E"
        android:textSize="14sp" />

    <!-- 历史列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- 日志区域 -->
    <LinearLayout
        android:id="@+id/layoutLog"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="#0A0D14"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="运行日志"
                android:textColor="#5A5E6E"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/btnCopyLog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp"
                android:text="📋 复制"
                android:textColor="#4F6EF7"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/btnClearLog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp"
                android:paddingStart="12dp"
                android:text="清空"
                android:textColor="#F87171"
                android:textSize="11sp" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="等待操作..."
                android:textColor="#6B7280"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textIsSelectable="true" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
